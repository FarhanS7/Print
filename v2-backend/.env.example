# V2 Try-On Service Environment Variables

PORT=5001
MONGODB_URI=mongodb://localhost:27017/printify-custom

# Cloudinary (shared with V1)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# fal.ai — Virtual Try-On Provider
FAL_KEY=

# Redis — BullMQ Queue Backend
REDIS_URL=redis://localhost:6379

# Try-On Limits
TRYON_DAILY_LIMIT=5
TRYON_CONCURRENT_LIMIT=2
TRYON_COOLDOWN_SECONDS=30
TRYON_INPUT_RETENTION_HOURS=24

# CORS
CLIENT_URL=http://localhost:5173
